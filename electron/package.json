{
  "name": "desktop-django-starter-electron",
  "version": "0.1.0",
  "private": true,
  "description": "Electron shell for the desktop Django starter.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test ./scripts/*.test.cjs",
    "stage-backend": "node ./scripts/stage-backend.cjs",
    "start:packaged": "npm run stage-backend && node ./scripts/launch-electron.cjs --runtime=packaged",
    "smoke:packaged": "npm run stage-backend && node ./scripts/launch-electron.cjs --runtime=packaged --smoke-test"
  },
  "devDependencies": {
    "electron": "40.0.0"
  }
}
